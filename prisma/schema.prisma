generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["audit", "cost", "dashboard", "delivery", "inventory", "order", "public"]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

model Realm {
  id               String     @id @default(cuid())
  realmId          String     @unique @map("realm_id")
  name             String
  accessToken      String?    @map("access_token")
  refreshToken     String?    @map("refresh_token")
  expiresAt        DateTime?  @map("expires_at")
  refreshExpiresAt DateTime?  @map("refresh_expires_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  locations        Location[]

  @@map("realms")
  @@schema("public")
}

model Location {
  id               String        @id @default(cuid())
  code             String        @unique
  name             String
  createdAt        DateTime      @default(now()) @map("created_at")
  classId          String?       @map("class_id")
  realmId          String        @map("realm_id")
  startYearMonth   String?       @map("start_year_month")
  showBudget       Boolean       @default(true) @map("show_budget")
  cloverMerchantId String?       @map("clover_merchant_id")
  cloverToken      String?       @map("clover_token")
  budgets          Budget[]
  laborTargets     LaborTarget[]
  revenueAnnualGoals  RevenueAnnualGoal[]
  revenueMonthTargets RevenueMonthTarget[]
  realm            Realm         @relation(fields: [realmId], references: [id])
  users            User[]

  @@map("locations")
  @@schema("public")
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String?           @unique
  emailVerified   DateTime?         @map("email_verified")
  image           String?
  role            UserRole?         @default(manager)
  status          UserStatus        @default(pending_onboarding) @map("status")
  locationId      String?           @map("location_id")
  permittedById   String?           @map("permitted_by_id")
  permittedAt     DateTime?         @map("permitted_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  rejectReason    String?           @map("reject_reason")
  budgetSettings  BudgetSettings[]  @relation("BudgetSettingsUpdatedBy")
  costEditHistory CostEditHistory[]
  costMemos       CostMemo[]
  accounts        Account[]
  sessions        Session[]
  location        Location?         @relation(fields: [locationId], references: [id])
  permittedBy     User?             @relation("UserPermittedBy", fields: [permittedById], references: [id])
  permittedUsers  User[]            @relation("UserPermittedBy")
  /// delivery.Driver.userId → public.users.id (one driver profile per user)
  driver          Driver?

  @@map("users")
  @@schema("public")
}

enum UserRole {
  admin
  office
  manager
  assistant
  employee
  supplier

  @@schema("public")
}

enum UserStatus {
  pending_onboarding
  pending_approval
  active
  rejected

  @@schema("public")
}

// ===============================
// DASHBOARD (budget + labor targets)
// ===============================
model BudgetSettings {
  id                    String   @id @default(cuid())
  budgetRate            Decimal  @map("budget_rate") @db.Decimal(5, 4)
  referencePeriodMonths Int      @map("reference_period_months")
  updatedAt             DateTime @updatedAt @map("updated_at")
  updatedById           String?  @map("updated_by_id")
  updatedBy             User?    @relation("BudgetSettingsUpdatedBy", fields: [updatedById], references: [id])

  @@map("budget_settings")
  @@schema("dashboard")
}

model Budget {
  id                        String   @id @default(cuid())
  locationId                String   @map("location_id")
  yearMonth                 String   @map("year_month")
  totalAmount               Decimal  @map("total_amount") @db.Decimal(14, 2)
  createdAt                 DateTime @default(now()) @map("created_at")
  budgetRateUsed            Decimal? @map("budget_rate_used") @db.Decimal(5, 4)
  referencePeriodMonthsUsed Int?     @map("reference_period_months_used")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  error                     String?  @map("error")
  location                  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, yearMonth])
  @@map("budgets")
  @@schema("dashboard")
}

/**
 * Labor dashboard target (rate × ref income ÷ months). Independent of Cost budget.
 */
model LaborTarget {
  id                    String   @id @default(cuid())
  locationId            String   @map("location_id")
  yearMonth             String   @map("year_month")
  rate                  Decimal  @map("rate") @db.Decimal(5, 4)
  referencePeriodMonths Int      @map("reference_period_months")
  updatedAt             DateTime @updatedAt @map("updated_at")
  location              Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, yearMonth])
  @@map("labor_targets")
  @@schema("dashboard")
}

/// Calendar-year revenue goal per location (can change year over year).
model RevenueAnnualGoal {
  id           String   @id @default(cuid())
  locationId   String   @map("location_id")
  calendarYear Int      @map("calendar_year")
  goalAmount   Decimal  @map("goal_amount") @db.Decimal(14, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, calendarYear])
  @@map("revenue_annual_goals")
  @@schema("dashboard")
}

/**
 * Clover weekday/holiday mix for a specific dashboard month (YYYY-MM).
 * `referencePeriodMonths` = full calendar months before `appliesYearMonth` (excluded) for Clover lookback; 0 = no mix / no targets from this row.
 * `refYearMonth` kept for legacy rows; new writes mirror `appliesYearMonth`.
 */
model RevenueMonthTarget {
  id                      String   @id @default(cuid())
  locationId              String   @map("location_id")
  appliesYearMonth        String   @map("applies_year_month")
  referencePeriodMonths   Int      @default(12) @map("reference_period_months")
  sharesJson              String   @map("shares_json") @db.Text
  computedAt              DateTime @map("computed_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  location                Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, appliesYearMonth])
  @@map("revenue_month_targets")
  @@schema("dashboard")
}

// ===============================
// COST (from bh-cost-analysis; no Organization)
// ===============================
model Cost {
  id               String            @id @default(cuid())
  title            String
  totalCount       Int
  lossAmount       Float?
  finalWeight      Float?
  locked           Boolean           @default(false)
  ingredients      Ingredient[]
  packagings       Packaging[]
  labors           Labor[]
  others           Other[]
  prices           Price[]
  tags             CostTag[]
  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz
  CostEditHistory  CostEditHistory[]
  costMemos        CostMemo[]
  costTagRelations CostTagRelation[]

  @@map("costs")
  @@schema("cost")
}

model Ingredient {
  id        String   @id @default(cuid())
  title     String
  unit      String
  amount    Float
  costId    String
  variantId String
  type      String   @default("")
  image     Json?
  rank      String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("ingredients")
  @@schema("cost")
}

model Packaging {
  id        String   @id @default(cuid())
  title     String
  unit      String
  amount    Float
  costId    String
  variantId String
  type      String   @default("")
  image     Json?
  rank      String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("packagings")
  @@schema("cost")
}

model Labor {
  id        String   @id @default(cuid())
  title     String
  time      Float
  people    Int
  wage      Float
  costId    String
  rank      String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("labors")
  @@schema("cost")
}

model Other {
  id        String   @id @default(cuid())
  title     String
  amount    Float
  costId    String
  rank      String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("others")
  @@schema("cost")
}

model Price {
  id           String   @id @default(cuid())
  title        String
  margin       Float
  price        Float
  costId       String
  base         String?
  rank         String
  isFinalPrice Boolean  @default(false)
  Cost         Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@map("prices")
  @@schema("cost")
}

model CostTag {
  id               String            @id @default(cuid())
  name             String
  color            String            @default("gray")
  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz
  cost             Cost?             @relation(fields: [costId], references: [id])
  costId           String?
  costTagRelations CostTagRelation[]

  @@map("tags")
  @@schema("cost")
}

model CostTagRelation {
  costId String
  tagId  String
  Cost   Cost    @relation(fields: [costId], references: [id], onDelete: Cascade)
  Tag    CostTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([costId, tagId])
  @@map("cost_tags")
  @@schema("cost")
}

model CostEditHistory {
  id        String   @id @default(cuid())
  costId    String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  userId    String
  User      User     @relation(fields: [userId], references: [id], onDelete: NoAction)
  log       Json
  createdAt DateTime @default(now()) @db.Timestamptz

  @@map("cost_edit_history")
  @@schema("cost")
}

model CostMemo {
  id        String   @id @default(cuid())
  costId    String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  userId    String
  User      User     @relation(fields: [userId], references: [id], onDelete: NoAction)
  memo      String
  rank      String
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("cost_memos")
  @@schema("cost")
}

model ShopifyConfig {
  id                 String   @id @default(cuid())
  shopifyUrl         String
  adminToken         String
  apiVersion         String
  query              String?
  costFieldConfig    Json[]
  productFieldConfig Json[]
  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz

  @@map("shopify_config")
  @@schema("cost")
}

model PriceConfig {
  id            String   @id @default(cuid())
  defaultPrices Json[]
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  @@map("price_config")
  @@schema("cost")
}

// ===============================
// DELIVERY (driver scheduling)
// DeliveryLocation: main locations for everyday schedule (can reference public Location).
// Occasional locations for one-time events are stored inline in DailyScheduleStop (name/address/lat/lng).
// ===============================
model DeliveryLocation {
  id         String   @id @default(cuid())
  name       String
  address    String?
  lat        Float?
  lng        Float?
  locationId String?  @map("location_id") // optional FK to public.Location for future 물류/재고
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  dailyStops DailyScheduleStop[]
  fixedStops FixedScheduleStop[]

  @@map("delivery_locations")
  @@schema("delivery")
}

model Driver {
  id                      String    @id @default(cuid())
  userId                  String    @unique @map("user_id") // User (public) who is this driver
  /// Set when office requests a fresh GPS fix; cleared when the driver app POSTs location.
  locationPingRequestedAt DateTime? @map("location_ping_requested_at") @db.Timestamptz
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  fixedSchedules  DriverFixedSchedule[]
  dailyStops      DailyScheduleStop[]
  locationUpdates DriverLocationUpdate[]

  @@map("drivers")
  @@schema("delivery")
}

// Day of week: 0=Sunday, 1=Monday, ..., 6=Saturday. Recurring: e.g. TUE=3, THU=5.
// Template stops/tasks define the recurring schedule; when the date comes, daily schedule is created from this template.
model DriverFixedSchedule {
  id        String   @id @default(cuid())
  driverId  String   @map("driver_id")
  dayOfWeek Int      @map("day_of_week") // 0-6
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  driver        Driver              @relation(fields: [driverId], references: [id], onDelete: Cascade)
  templateStops FixedScheduleStop[]

  @@unique([driverId, dayOfWeek])
  @@map("driver_fixed_schedules")
  @@schema("delivery")
}

// Template stop for a recurring weekday (same shape as DailyScheduleStop for copy-to-daily).
model FixedScheduleStop {
  id                 String   @id @default(cuid())
  fixedScheduleId    String   @map("fixed_schedule_id")
  sequence           Int      @map("sequence")
  deliveryLocationId String?  @map("delivery_location_id")
  name               String   @map("name")
  address            String?  @map("address")
  lat                Float?   @map("lat")
  lng                Float?   @map("lng")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  fixedSchedule    DriverFixedSchedule @relation(fields: [fixedScheduleId], references: [id], onDelete: Cascade)
  deliveryLocation DeliveryLocation?   @relation(fields: [deliveryLocationId], references: [id], onDelete: SetNull)
  tasks            FixedScheduleTask[]

  @@map("fixed_schedule_stops")
  @@schema("delivery")
}

model FixedScheduleTask {
  id                  String   @id @default(cuid())
  fixedScheduleStopId String   @map("fixed_schedule_stop_id")
  title               String   @map("title")
  sequence            Int      @map("sequence")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  fixedScheduleStop FixedScheduleStop @relation(fields: [fixedScheduleStopId], references: [id], onDelete: Cascade)

  @@map("fixed_schedule_tasks")
  @@schema("delivery")
}

// Daily stops are keyed by date + driver; no separate Schedule table. Query by date (and driverId) to get a "schedule".
model DailyScheduleStop {
  id                 String    @id @default(cuid())
  date               DateTime  @db.Date
  driverId           String    @map("driver_id")
  sequence           Int       @map("sequence")
  deliveryLocationId String?   @map("delivery_location_id")
  name               String    @map("name") // from location or occasional
  address            String?   @map("address")
  lat                Float?    @map("lat")
  lng                Float?    @map("lng")
  arrivedAt          DateTime? @map("arrived_at") @db.Timestamptz
  departedAt         DateTime? @map("departed_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  driver           Driver              @relation(fields: [driverId], references: [id], onDelete: Cascade)
  deliveryLocation DeliveryLocation?   @relation(fields: [deliveryLocationId], references: [id], onDelete: SetNull)
  tasks            DailyScheduleTask[]

  @@index([date, driverId])
  @@map("daily_schedule_stops")
  @@schema("delivery")
}

model DailyScheduleTask {
  id                  String    @id @default(cuid())
  dailyScheduleStopId String    @map("daily_schedule_stop_id")
  title               String    @map("title")
  sequence            Int       @map("sequence")
  assignedById        String?   @map("assigned_by_id")
  assignedAt          DateTime? @map("assigned_at") @db.Timestamptz
  completedAt         DateTime? @map("completed_at") @db.Timestamptz
  isDismissed         Boolean   @default(false) @map("is_dismissed")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  dailyScheduleStop DailyScheduleStop @relation(fields: [dailyScheduleStopId], references: [id], onDelete: Cascade)

  @@map("daily_schedule_tasks")
  @@schema("delivery")
}

// GPS updates from driver app for office to see current location and today's route (이동경로)
model DriverLocationUpdate {
  id        String   @id @default(cuid())
  driverId  String   @map("driver_id")
  lat       Float    @map("lat")
  lng       Float    @map("lng")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, createdAt])
  @@map("driver_location_updates")
  @@schema("delivery")
}

// ===============================
// ORDER (Purchase orders — migrated from Shopify Auto Purchase Orders export)
// ===============================
model PurchaseOrder {
  id                    String                      @id @default(cuid())
  /// Shopify app PO id from export `ID` column (stable key for idempotent import).
  legacyExternalId      Int?                        @unique @map("legacy_external_id")
  poNumber              String                      @map("po_number")
  status                String
  currency              String
  isAuto                Boolean                     @default(false) @map("is_auto")
  displayTaxColumn      Boolean                     @default(false) @map("display_tax_column")
  comment               String?                     @db.Text
  authorizedBy          String?                     @map("authorized_by")
  unitsOrdered          Int?                        @map("units_ordered")
  dateCreated           DateTime?                   @map("date_created") @db.Date
  expectedDate          DateTime?                   @map("expected_date") @db.Date
  subtotalPrice         Decimal?                    @map("subtotal_price") @db.Decimal(14, 2)
  discount              Decimal?                    @map("discount") @db.Decimal(14, 2)
  discountReason        String?                     @map("discount_reason") @db.Text
  shippingHandlingPrice Decimal?                    @map("shipping_handling_price") @db.Decimal(14, 2)
  totalTaxPrice         Decimal?                    @map("total_tax_price") @db.Decimal(14, 2)
  totalPrice            Decimal?                    @map("total_price") @db.Decimal(14, 2)
  sourceCreatedAt       DateTime?                   @map("source_created_at") @db.Timestamptz
  sourceUpdatedAt       DateTime?                   @map("source_updated_at") @db.Timestamptz
  completedAt           DateTime?                   @map("completed_at") @db.Timestamptz
  supplierExternalId    Int?                        @map("supplier_external_id")
  supplierCompany       String?                     @map("supplier_company")
  supplierContactName   String?                     @map("supplier_contact_name")
  /// One PO can combine multiple Shopify orders — contact/addresses live per linked order.
  shopifyOrderRefs      PurchaseOrderShopifyOrder[]
  lineItems             PurchaseOrderLineItem[]
  createdAt             DateTime                    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime                    @updatedAt @map("updated_at") @db.Timestamptz

  @@index([poNumber])
  @@index([status])
  @@index([supplierExternalId])
  @@map("purchase_orders")
  @@schema("order")
}

/// One row per Shopify order linked to a PO (combined PO ⇒ multiple rows). Customer/address match that order.
model PurchaseOrderShopifyOrder {
  id              String        @id @default(cuid())
  purchaseOrderId String        @map("purchase_order_id")
  /// Display ref as in Shopify/export (e.g. `#1689`). Import uses `(unknown)` when the CSV had no order #.
  orderNumber     String        @map("shopify_order_number")
  customerPhone   String?       @map("shopify_order_customer_phone")
  customerEmail   String?       @map("shopify_order_customer_email")
  billingAddress  Json?         @map("billing_address")
  shippingAddress Json?         @map("shipping_address")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@unique([purchaseOrderId, orderNumber])
  @@index([orderNumber])
  @@map("purchase_order_shopify_orders")
  @@schema("order")
}

model PurchaseOrderLineItem {
  id                      String        @id @default(cuid())
  purchaseOrderId         String        @map("purchase_order_id")
  /// Export `Product ID` column (may repeat or be absent).
  legacyLineExternalId    Int?          @map("legacy_line_external_id")
  /// Row order within the PO in the export file.
  sequence                Int           @map("sequence")
  quantity                Int
  quantityReceived        Int           @default(0) @map("quantity_received")
  supplierRef             String?       @map("supplier_ref") @db.Text
  taxPercent              Decimal?      @map("tax_percent") @db.Decimal(9, 4)
  sku                     String?
  variantTitle            String?       @map("variant_title")
  productTitle            String?       @map("product_title") @db.Text
  shopifyInventoryItemGid String?       @map("shopify_inventory_item_gid")
  shopifyVariantGid       String?       @map("shopify_variant_gid")
  shopifyProductGid       String?       @map("shopify_product_gid")
  isCustom                Boolean       @default(false) @map("is_custom")
  itemPrice               Decimal?      @map("item_price") @db.Decimal(14, 2)
  lineSubtotalPrice       Decimal?      @map("line_subtotal_price") @db.Decimal(14, 2)
  lineTotalTaxPrice       Decimal?      @map("line_total_tax_price") @db.Decimal(14, 2)
  productProperties       String?       @map("product_properties") @db.Text
  purchaseOrder           PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@unique([purchaseOrderId, sequence])
  @@index([purchaseOrderId, legacyLineExternalId])
  @@map("purchase_order_line_items")
  @@schema("order")
}
